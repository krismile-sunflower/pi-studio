{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pi-studio",
  "version": "0.1.0",
  "identifier": "app.pi.studio",
  "build": {
    "beforeDevCommand": "pnpm dev:desktop",
    "beforeBuildCommand": "pnpm build:desktop",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "pi-studio",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/tau-192.png"
    ],
    "resources": {
      "extensions": "extensions",
      "binaries": "binaries",
      "../dist": "tau-web"
    }
  }
}
